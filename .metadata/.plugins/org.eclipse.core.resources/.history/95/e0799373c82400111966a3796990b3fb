package com.personal_webflux.entity;

import org.springframework.data.relational.core.mapping.Table;

import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.NoArgsConstructor;

@Table
@NoArgsConstructor
@AllArgsConstructor
@Data
public class Personal {

	
	private int id;
	
	
	 `Id` int NOT NULL AUTO_INCREMENT,
	  `NOMBRE` char(60) CHARACTER SET latin1 COLLATE latin1_spanish_ci NOT NULL,
	  `DIRECCION` char(90) CHARACTER SET latin1 COLLATE latin1_spanish_ci NOT NULL,
	  `REGION` varchar(2) CHARACTER SET latin1 COLLATE latin1_spanish_ci DEFAULT NULL,
	  `PROVINCIA` varchar(2) CHARACTER SET latin1 COLLATE latin1_spanish_ci DEFAULT NULL,
	  `DISTRITO` varchar(2) CHARACTER SET latin1 COLLATE latin1_spanish_ci DEFAULT NULL,
	  `PAIS` varchar(2) CHARACTER SET latin1 COLLATE latin1_spanish_ci DEFAULT '1',
	  `DOCIDENTIDAD` char(15) CHARACTER SET latin1 COLLATE latin1_spanish_ci DEFAULT NULL,
	  `IDRUC` char(11) CHARACTER SET latin1 COLLATE latin1_spanish_ci DEFAULT NULL,
	  `FECHA_ING` date DEFAULT NULL,
	  `FECHA_NAC` date DEFAULT NULL,
	  `TELEFONO` char(10) CHARACTER SET latin1 COLLATE latin1_spanish_ci DEFAULT NULL,
	  `MOVIL` char(12) CHARACTER SET latin1 COLLATE latin1_spanish_ci DEFAULT NULL,
	  `EMAIL` char(50) CHARACTER SET latin1 COLLATE latin1_spanish_ci DEFAULT NULL,
	  `PROFESION` varchar(2) CHARACTER SET latin1 COLLATE latin1_spanish_ci DEFAULT NULL,
	  `AREATRABAJO` varchar(2) CHARACTER SET latin1 COLLATE latin1_spanish_ci DEFAULT NULL,
	  `ACTIVO` int DEFAULT '1',
	  `REGISTRO` timestamp NOT NULL DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP,
	  `USUARIO` int(10) unsigned zerofill DEFAULT '0000000001',
	  `IMAGEN` blob,
	  `OLD_ID` int unsigned DEFAULT NULL,
	  `SW` int unsigned NOT NULL DEFAULT '1'
	
	
	
	
}
