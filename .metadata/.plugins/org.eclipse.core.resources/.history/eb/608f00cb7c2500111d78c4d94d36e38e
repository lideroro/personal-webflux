package com.personal_webflux.controller;

import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.personal_webflux.service.PersonalService;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;

@RestController
@RequestMapping("/Personal")
@Slf4j
@RequiredArgsConstructor
public class PersonalController {

	private final PersonalService personalService = new PersonalService();
	
	@GetMapping
	public Flux<Personal> getAll() {
		return personalService.getAll();
	}
	
}
